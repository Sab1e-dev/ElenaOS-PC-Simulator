	// tasks.json section
	"tasks": {
		"version": "2.0.0",
		"tasks": [
			{
				"label": "Configure CMake",
				"type": "shell",
				"command": "cmake",
				"args": [
					"-S",
					"${workspaceFolder}",
					"-B",
					"${workspaceFolder}/build",
					"-DEOS_PLATFORM=Native"
				],
				"windows": {
					"args": [
						"-S",
						"${workspaceFolder}",
						"-B",
						"${workspaceFolder}/build",
						"-DEOS_PLATFORM=Native",
						"-DCMAKE_C_COMPILER=C:/msys64/mingw64/bin/gcc.exe",
						"-DCMAKE_CXX_COMPILER=C:/msys64/mingw64/bin/g++.exe"
					],
					"options": {
						"env": {
							"PATH": "C:/msys64/mingw64/bin;C:/msys64/usr/bin;${env:PATH}",
							"CC": "C:/msys64/mingw64/bin/gcc.exe",
							"CXX": "C:/msys64/mingw64/bin/g++.exe"
						}
					}
				},
				"problemMatcher": []
			},
			{
				"label": "Build",
				"type": "shell",
				"command": "cmake",
				"args": [
					"--build",
					"${workspaceFolder}/build"
				],
				"windows": {
					"options": {
						"env": {
							"PATH": "C:/msys64/mingw64/bin;C:/msys64/usr/bin;${env:PATH}"
						}
					}
				},
				"dependsOn": "Configure CMake",
				"dependsOrder": "sequence",
				"group": {
					"kind": "build",
					"isDefault": true
				},
				"problemMatcher": {
					"owner": "cpp",
					"fileLocation": [
						"relative",
						"${workspaceFolder}"
					],
					"pattern": {
						"regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
						"file": 1,
						"line": 2,
						"column": 3,
						"severity": 4,
						"message": 5
					}
				}
			},
			{
				"label": "Build and Run",
				"type": "shell",
				"command": "${workspaceFolder}/bin/main",
				"windows": {
					"command": "${workspaceFolder}/bin/main.exe"
				},
				"group": {
					"kind": "test",
					"isDefault": true
				},
				"dependsOn": "Build"
			},
			{
				"label": "Configure WASM",
				"type": "shell",
				"command": "bash",
				"args": [
					"-lc",
					"WORKSPACE=\"${workspaceFolder}\"; if [ -n \"$EMSDK\" ] && [ -f \"$EMSDK/emsdk_env.sh\" ]; then EMSDK_ROOT=\"$EMSDK\"; elif [ -f \"$WORKSPACE/../emsdk/emsdk_env.sh\" ]; then EMSDK_ROOT=\"$(cd \"$WORKSPACE/../emsdk\" && pwd)\"; else echo \"Unable to locate emsdk. Set EMSDK or place emsdk at ../emsdk relative to the workspace.\"; exit 1; fi; . \"$EMSDK_ROOT/emsdk_env.sh\" >/dev/null && emcmake cmake -S \"$WORKSPACE\" -B \"$WORKSPACE/build-wasm\" -DEOS_PLATFORM=WASM -DCMAKE_BUILD_TYPE=Debug"
				],
				"problemMatcher": []
			},
			{
				"label": "Build WASM",
				"type": "shell",
				"command": "bash",
				"args": [
					"-lc",
					"WORKSPACE=\"${workspaceFolder}\"; if [ -n \"$EMSDK\" ] && [ -f \"$EMSDK/emsdk_env.sh\" ]; then EMSDK_ROOT=\"$EMSDK\"; elif [ -f \"$WORKSPACE/../emsdk/emsdk_env.sh\" ]; then EMSDK_ROOT=\"$(cd \"$WORKSPACE/../emsdk\" && pwd)\"; else echo \"Unable to locate emsdk. Set EMSDK or place emsdk at ../emsdk relative to the workspace.\"; exit 1; fi; . \"$EMSDK_ROOT/emsdk_env.sh\" >/dev/null && cmake --build \"$WORKSPACE/build-wasm\""
				],
				"dependsOn": "Configure WASM",
				"dependsOrder": "sequence",
				"group": "build",
				"problemMatcher": {
					"owner": "cpp",
					"fileLocation": [
						"absolute"
					],
					"pattern": {
						"regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
						"file": 1,
						"line": 2,
						"column": 3,
						"severity": 4,
						"message": 5
					}
				}
			},
			{
				"label": "Build WASM and Serve",
				"dependsOn": "Build WASM",
				"dependsOrder": "sequence",
				"problemMatcher": []
			}
		],
	},
	// launch.json section
	"launch": {
