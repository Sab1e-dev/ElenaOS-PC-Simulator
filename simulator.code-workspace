					"MIMode": "gdb",
					"miDebuggerPath": "/usr/bin/gdb"
				},
				"osx": {
					"MIMode": "lldb",
					// "externalConsole": true
				},
				"windows": {
					"MIMode": "gdb",
					"program": "${workspaceFolder}\\bin\\main.exe",
					"miDebuggerPath": "C:\\msys64\\mingw64\\bin\\gdb.exe"
				}
